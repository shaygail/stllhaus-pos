# Example .env for Railway Postgres
# Replace <username>, <password>, <host>, <port>, <database> with your Railway credentials
DATABASE_URL=postgresql+asyncpg://postgres:BOxXfQvEpIIaHEWTNvqtuYzDxbVoueMO@stllhaus-pos-production.up.railway.app:<port>/<database>
SECRET_KEY=your-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

python3 -m venv .venv
source .venv/bin/activate
pip install -r backend/requirements.txt

../.venv/bin/python -m uvicorn app.main:app --reload

{
  "name": "stllhaus-pos",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next dev",
    "dev:clean": "rm -rf .next && cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next dev",
    "verify": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next build && tsc --noEmit",
    "verify:clean": "rm -rf .next && cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next build && tsc --noEmit",
    "build": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next build",
    "start": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next start",
    "lint": "eslint ."
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "14.2.35",
    "object-hash": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "recharts": "^2.15.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5"
  }
